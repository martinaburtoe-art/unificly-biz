# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env real -- ya está en .gitignore.

# --- Supabase (públicas, usadas en cliente y servidor) ---
SUPABASE_PROJECT_ID=tu-proyecto-id
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu-anon-key-publica
VITE_SUPABASE_PROJECT_ID=tu-proyecto-id
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu-anon-key-publica

# --- Supabase (secreta, SOLO servidor -- nunca exponer con prefijo VITE_) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (secreta, solo servidor) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# --- WhatsApp / Meta Cloud API (secreta, solo servidor) ---
META_APP_SECRET=
META_WHATSAPP_VERIFY_TOKEN=

# --- IA (Lovable AI Gateway, secreta, solo servidor) ---
LOVABLE_API_KEY=

# --- Cron jobs (secreta, protege /api/quotes/follow-up y /api/collections/check-overdue) ---
CRON_SECRET=

# --- General ---
SITE_URL=http://localhost:3000
